# Serveur
PORT=5000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=reservation_salle

# JSON Web Token
# Générer un secret fort (min 32 caractères) avec :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=votre_secret_jwt_à_changer
JWT_EXPIRES_IN=7d
